{
  "compilerOptions": {
    "target": "ES2021",
    "module": "Node16",
    "lib": ["ES2021"],
    "strict": false,
    "moduleResolution": "node16",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": ".medusa/server",
    "rootDir": ".",
    "paths": {}
  },
  "ts-node": {
    "transpileOnly": true,
    "compilerOptions": {
      "module": "Node16",
      "moduleResolution": "node16"
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", ".medusa"]
}
